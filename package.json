{
  "name": "clip-vertical-editor",
  "version": "4.3.0",
  "description": "CapCut-style editor for turning Twitch clips into vertical TikTok/Reels/Shorts videos.",
  "main": "electron/main.js",
  "author": "SnowwyHimself",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "fetch-binaries:mac": "bash scripts/fetch-binaries-mac.sh",
    "fetch-binaries:win": "bash scripts/fetch-binaries-win.sh",
    "fetch-whisper-model": "bash scripts/fetch-whisper-model.sh",
    "build-whisper": "bash scripts/build-whisper-mac.sh",
    "dist:mac": "npm run fetch-binaries:mac && electron-builder --mac --arm64",
    "dist:win": "npm run fetch-binaries:win && electron-builder --win --x64"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "electron-updater": "^6.8.9",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "multicast-dns": "^7.2.5",
    "opentype.js": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.clipeditor.app",
    "productName": "Clip Editor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "transfer-server.js",
      "caption.js",
      "transcribe.js",
      "release-notes.json",
      "public/**/*",
      "fonts/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**"
    ],
    "afterSign": "scripts/afterSign.js",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.video",
      "extraResources": [
        {
          "from": "resources/bin-mac",
          "to": "bin"
        },
        {
          "from": "models",
          "to": "models"
        }
      ],
      "artifactName": "Clip-Editor-Mac.${ext}",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "resources/bin-win",
          "to": "bin"
        },
        {
          "from": "models",
          "to": "models"
        }
      ],
      "artifactName": "Clip-Editor-Windows-Setup.${ext}",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SnowwyHimself",
        "repo": "twitch-clip-editor"
      }
    ]
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true
  }
}
